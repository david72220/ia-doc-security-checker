---
interface Model {
  id: string;
  label: string;
  editor: string;
  jurisdiction: string;
  jurisdiction_flag: string;
  data_retention: string;
  training_on_data: boolean;
  risk_level: string;
  risk_description: string;
  safe_for_levels: string[];
}

interface Props {
  models: Model[];
  i18n: any;
  category: 'recommended' | 'caution' | 'forbidden';
}

const { models, i18n, category } = Astro.props;

const categoryConfig = {
  recommended: {
    bg: 'bg-green-50',
    border: 'border-green-200',
    header: 'text-green-800',
    icon: '✅',
    label: i18n.model.recommended,
  },
  caution: {
    bg: 'bg-yellow-50',
    border: 'border-yellow-200',
    header: 'text-yellow-800',
    icon: '⚠️',
    label: i18n.model.caution,
  },
  forbidden: {
    bg: 'bg-red-50',
    border: 'border-red-200',
    header: 'text-red-800',
    icon: '❌',
    label: i18n.model.not_recommended,
  },
};

const c = categoryConfig[category];
---

<div class={`rounded-xl border ${c.border} ${c.bg} overflow-hidden`}>
  <div class={`px-4 py-3 ${c.header} font-semibold flex items-center gap-2`}>
    <span class="text-lg">{c.icon}</span>
    <span>{c.label}</span>
    <span class="ml-auto text-sm opacity-70">({models.length})</span>
  </div>

  <div class="overflow-x-auto">
    <table class="model-table w-full">
      <thead class="bg-white/50">
        <tr class="text-left text-sm text-slate-600">
          <th class="px-4 py-2 font-medium">{i18n.model.model}</th>
          <th class="px-4 py-2 font-medium">{i18n.model.jurisdiction}</th>
          <th class="px-4 py-2 font-medium">{i18n.model.retention}</th>
          <th class="px-4 py-2 font-medium">{i18n.model.training}</th>
          <th class="px-4 py-2 font-medium">{i18n.model.risk}</th>
        </tr>
      </thead>
      <tbody>
        {models.map((m) => (
          <tr class="border-t border-slate-200 text-sm hover:bg-white/30">
            <td class="px-4 py-3" data-label={i18n.model.model}>
              <div class="font-medium text-slate-800">{m.label}</div>
              <div class="text-xs text-slate-500">{m.editor}</div>
            </td>
            <td class="px-4 py-3" data-label={i18n.model.jurisdiction}>
              <span class="text-lg">{m.jurisdiction_flag}</span>
              <span class="ml-1 text-xs text-slate-600">{m.jurisdiction}</span>
            </td>
            <td class="px-4 py-3 text-slate-600" data-label={i18n.model.retention}>
              {m.data_retention}
            </td>
            <td class="px-4 py-3" data-label={i18n.model.training}>
              {m.training_on_data ? (
                <span class="text-red-600 font-medium">⚠️ {i18n.model.training}</span>
              ) : (
                <span class="text-green-600">✓</span>
              )}
            </td>
            <td class="px-4 py-3" data-label={i18n.model.risk}>
              <span class={`px-2 py-1 rounded text-xs font-medium ${
                m.risk_level === 'none' ? 'bg-green-100 text-green-700' :
                m.risk_level === 'low' ? 'bg-green-100 text-green-700' :
                m.risk_level === 'medium' ? 'bg-yellow-100 text-yellow-700' :
                m.risk_level === 'high' ? 'bg-orange-100 text-orange-700' :
                'bg-red-100 text-red-700'
              }`}>
                {m.risk_description}
              </span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>