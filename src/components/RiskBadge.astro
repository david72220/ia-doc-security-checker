---
interface Props {
  level: 'low' | 'medium' | 'high' | 'critical';
  label?: string;
  description?: string;
}

const { level, label, description } = Astro.props;

const config = {
  low: {
    emoji: '🟢',
    bg: 'bg-green-100',
    text: 'text-green-800',
    border: 'border-green-300',
    badgeClass: '',
  },
  medium: {
    emoji: '🟡',
    bg: 'bg-yellow-100',
    text: 'text-yellow-800',
    border: 'border-yellow-300',
    badgeClass: '',
  },
  high: {
    emoji: '🔴',
    bg: 'bg-red-100',
    text: 'text-red-800',
    border: 'border-red-300',
    badgeClass: '',
  },
  critical: {
    emoji: '🔴🔴',
    bg: 'bg-red-900',
    text: 'text-white',
    border: 'border-red-700',
    badgeClass: 'badge-critical',
  },
};

const c = config[level];
---

<div class={`inline-flex items-center gap-2 px-4 py-2 rounded-xl border-2 ${c.bg} ${c.text} ${c.border} ${c.badgeClass} font-semibold`}>
  <span class="text-lg">{c.emoji}</span>
  <span>{label}</span>
</div>

{description && (
  <p class={`mt-2 text-sm ${c.text} opacity-80 max-w-2xl`}>{description}</p>
)}