---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, tObj } from '../../i18n/index';
import sectorsFr from '../../data/sectors.fr.json';
import sectorsEn from '../../data/sectors.en.json';

export function getStaticPaths() {
  return [{ params: { lang: 'fr' } }, { params: { lang: 'en' } }];
}

const lang = getLangFromUrl(Astro.url);
const i18n = tObj(lang);
const sectors = (lang === 'fr' ? sectorsFr : sectorsEn).sectors;

const businessType = Astro.url.searchParams.get('type') || 'all';

const iconMap: Record<string, string> = {
  calculator: 'M9 7h6m0 10v-3m-6 3h.01M9 14h.01M9 17h.01M12 14h.01M12 17h.01M15 14h.01M15 17h.01M5 5h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2z',
  briefcase: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  scale: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3',
  users: 'M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-5.13a4 4 0 11-8 0 4 4 0 018 0zm6 0a4 4 0 11-8 0 4 4 0 018 0z',
  megaphone: 'M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z',
  code: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  heart: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
  building: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3-1.5L12 21l3-1.5L19 21zM9 9h1m4 0h1M9 13h1m4 0h1',
};
---

<Layout>
  <section class="py-8 px-4">
    <div class="max-w-7xl mx-auto">
      <!-- Search bar -->
      <div class="mb-8">
        <div class="relative max-w-2xl mx-auto">
          <input
            type="text"
            id="doc-search"
            placeholder={i18n.search.placeholder}
            class="w-full px-5 py-3 pl-12 rounded-xl border-2 border-slate-200 focus:border-blue-500 focus:outline-none text-lg"
          />
          <svg class="absolute left-4 top-3.5 w-6 h-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <div id="search-results" class="hidden absolute top-full left-0 right-0 mt-2 bg-white rounded-xl shadow-lg border border-slate-200 max-h-96 overflow-y-auto z-50"></div>
        </div>
        <div class="text-center mt-3 text-sm text-slate-500">
          <span class="font-medium">{i18n.search.popular}:</span>
          <button class="search-suggest ml-2 text-blue-600 hover:underline" data-doc="facture">Facture</button>
          <span class="mx-1">·</span>
          <button class="search-suggest text-blue-600 hover:underline" data-doc="contrat">Contrat</button>
          <span class="mx-1">·</span>
          <button class="search-suggest text-blue-600 hover:underline" data-doc="fiche-paie">Fiche de paie</button>
          <span class="mx-1">·</span>
          <button class="search-suggest text-blue-600 hover:underline" data-doc="devis">Devis</button>
        </div>
      </div>

      <!-- Sector grid -->
      <h2 class="text-2xl font-bold text-slate-800 mb-6 text-center">{i18n.home.step1}</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {sectors.map((sector: any) => (
          <div class="sector-card bg-white rounded-xl border-2 border-slate-200 hover:border-blue-400 hover:shadow-lg transition-all p-5 cursor-pointer" data-sector={sector.id}>
            <div class="flex flex-col items-center text-center">
              <svg class="w-10 h-10 text-blue-600 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={iconMap[sector.icon] || iconMap.briefcase} />
              </svg>
              <h3 class="font-semibold text-slate-800 text-sm">{sector.label}</h3>
              <p class="text-xs text-slate-500 mt-1">{sector.documents.length} {lang === 'fr' ? 'types' : 'types'}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Document list (hidden by default, shown when sector is clicked) -->
      <div id="doc-list" class="hidden mt-8">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-xl font-bold text-slate-800" id="doc-list-title"></h3>
          <button id="back-to-sectors" class="text-sm text-blue-600 hover:underline">← {lang === 'fr' ? 'Retour aux secteurs' : 'Back to sectors'}</button>
        </div>
        <div id="doc-list-content" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3"></div>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ sectors, lang, i18n }}>
    // Sector click → show documents
    document.querySelectorAll('.sector-card').forEach(card => {
      card.addEventListener('click', () => {
        const sectorId = card.dataset.sector;
        const sector = sectors.find(s => s.id === sectorId);
        if (!sector) return;

        document.getElementById('doc-list-title').textContent = sector.label;
        const content = document.getElementById('doc-list-content');
        content.innerHTML = sector.documents.map(doc => {
          const riskEmoji = { low: '🟢', medium: '🟡', high: '🔴', critical: '🔴🔴' }[doc.sensitivity] || '🟡';
          const riskLabel = i18n.risk[doc.sensitivity] || doc.sensitivity;
          return `<a href="/${lang}/resultat?sector=${sector.id}&doc=${doc.id}" class="block p-4 bg-white rounded-xl border-2 border-slate-200 hover:border-blue-400 hover:shadow-md transition-all">
            <div class="flex items-center justify-between">
              <span class="font-medium text-slate-800">${doc.label}</span>
              <span class="text-lg">${riskEmoji}</span>
            </div>
            <p class="text-xs text-slate-500 mt-1">${riskLabel}</p>
          </a>`;
        }).join('');

        document.getElementById('doc-list').classList.remove('hidden');
        document.getElementById('doc-list').scrollIntoView({ behavior: 'smooth' });
      });
    });

    // Back button
    document.getElementById('back-to-sectors').addEventListener('click', () => {
      document.getElementById('doc-list').classList.add('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // Search functionality
    const searchInput = document.getElementById('doc-search');
    const searchResults = document.getElementById('search-results');

    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase().trim();
      if (query.length < 2) {
        searchResults.classList.add('hidden');
        return;
      }
      const results = [];
      sectors.forEach(sector => {
        sector.documents.forEach(doc => {
          if (doc.label.toLowerCase().includes(query) || sector.label.toLowerCase().includes(query) || doc.id.includes(query)) {
            results.push({ sector, doc });
          }
        });
      });
      if (results.length === 0) {
        searchResults.innerHTML = `<div class="px-4 py-3 text-slate-500 text-sm">${i18n.search.no_results}</div>`;
      } else {
        searchResults.innerHTML = results.map(({ sector, doc }) => {
          const riskEmoji = { low: '🟢', medium: '🟡', high: '🔴', critical: '🔴🔴' }[doc.sensitivity] || '🟡';
          return `<a href="/${lang}/resultat?sector=${sector.id}&doc=${doc.id}" class="block px-4 py-2 hover:bg-slate-50 border-b border-slate-100 last:border-0">
            <div class="flex items-center justify-between">
              <div>
                <span class="font-medium text-slate-800">${doc.label}</span>
                <span class="text-xs text-slate-500 ml-2">${sector.label}</span>
              </div>
              <span class="text-lg">${riskEmoji}</span>
            </div>
          </a>`;
        }).join('');
      }
      searchResults.classList.remove('hidden');
    });

    // Click outside to close search
    document.addEventListener('click', (e) => {
      if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
        searchResults.classList.add('hidden');
      }
    });

    // Suggestion buttons
    document.querySelectorAll('.search-suggest').forEach(btn => {
      btn.addEventListener('click', () => {
        searchInput.value = btn.textContent;
        searchInput.dispatchEvent(new Event('input'));
      });
    });
  </script>
</Layout>