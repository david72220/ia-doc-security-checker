---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, tObj } from '../../i18n/index';

export function getStaticPaths() {
  return [{ params: { lang: 'fr' } }, { params: { lang: 'en' } }];
}

const lang = getLangFromUrl(Astro.url);
const i18n = tObj(lang);
---

<Layout>
  <section class="py-8 px-4">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl font-bold text-slate-900 mb-2 text-center">{i18n.analyze.upload_title}</h1>

      <!-- Security banner -->
      <div class="bg-slate-900 text-white rounded-xl p-4 mb-6 text-center text-sm">
        {i18n.analyze.security_banner}
      </div>

      <!-- Upload zone -->
      <div id="upload-zone" class="upload-zone border-2 border-dashed border-slate-300 rounded-2xl p-12 text-center cursor-pointer hover:border-blue-400 hover:bg-blue-50/30 transition-all mb-6">
        <svg class="w-16 h-16 text-slate-400 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
        </svg>
        <p class="text-slate-600 font-medium">{i18n.analyze.upload_zone}</p>
        <p class="text-xs text-slate-400 mt-2">{i18n.analyze.upload_formats}</p>
        <input type="file" id="file-input" class="hidden" accept=".pdf,.docx,.txt,.md" />
      </div>

      <!-- Selected file info -->
      <div id="file-info" class="hidden bg-slate-50 rounded-xl p-4 mb-6 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <svg class="w-8 h-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <div>
            <p id="file-name" class="font-medium text-slate-800 text-sm"></p>
            <p id="file-size" class="text-xs text-slate-500"></p>
          </div>
        </div>
        <button id="file-remove" class="text-red-500 hover:text-red-700 text-sm">✕</button>
      </div>

      <!-- Analyze button -->
      <div class="text-center mb-6">
        <button
          id="analyze-btn"
          class="px-8 py-3 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          disabled
        >
          {i18n.analyze.analyze_btn}
        </button>
      </div>

      <!-- Progress -->
      <div id="progress" class="hidden mb-6">
        <div class="bg-white rounded-xl border border-slate-200 p-6 text-center">
          <div class="inline-block animate-spin rounded-full h-10 w-10 border-b-2 border-blue-600 mb-3"></div>
          <p id="progress-text" class="text-slate-600 font-medium">{i18n.analyze.analyzing}</p>
        </div>
      </div>

      <!-- Results -->
      <div id="results" class="hidden"></div>
    </div>
  </section>

  <script is:inline define:vars={{ lang, i18n }}>
    const API_URL = '';  // Same origin — Vercel serverless functions

    const token = sessionStorage.getItem('jwt_token');
    if (!token) {
      window.location.href = `/${lang}/login`;
    }

    // Upload zone interactions
    const uploadZone = document.getElementById('upload-zone');
    const fileInput = document.getElementById('file-input');
    const fileInfo = document.getElementById('file-info');
    const fileName = document.getElementById('file-name');
    const fileSize = document.getElementById('file-size');
    const fileRemove = document.getElementById('file-remove');
    const analyzeBtn = document.getElementById('analyze-btn');

    uploadZone.addEventListener('click', () => fileInput.click());

    uploadZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadZone.classList.add('dragover');
    });

    uploadZone.addEventListener('dragleave', () => {
      uploadZone.classList.remove('dragover');
    });

    uploadZone.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadZone.classList.remove('dragover');
      if (e.dataTransfer.files.length) {
        fileInput.files = e.dataTransfer.files;
        handleFileSelect(e.dataTransfer.files[0]);
      }
    });

    fileInput.addEventListener('change', (e) => {
      if (e.target.files.length) handleFileSelect(e.target.files[0]);
    });

    function handleFileSelect(file) {
      if (file.size > 5 * 1024 * 1024) {
        alert(i18n.analyze.upload_formats);
        return;
      }
      fileName.textContent = file.name;
      fileSize.textContent = (file.size / 1024).toFixed(1) + ' KB';
      uploadZone.classList.add('hidden');
      fileInfo.classList.remove('hidden');
      analyzeBtn.disabled = false;
    }

    fileRemove.addEventListener('click', () => {
      fileInput.value = '';
      uploadZone.classList.remove('hidden');
      fileInfo.classList.add('hidden');
      analyzeBtn.disabled = true;
    });

    // Analyze
    analyzeBtn.addEventListener('click', async () => {
      const file = fileInput.files[0];
      if (!file) return;

      analyzeBtn.disabled = true;
      document.getElementById('progress').classList.remove('hidden');
      document.getElementById('results').classList.add('hidden');
      document.getElementById('progress-text').textContent = i18n.analyze.analyzing;

      const formData = new FormData();
      formData.append('file', file);

      try {
        const res = await fetch(`${API_URL}/api/analyze`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
          body: formData,
        });

        if (res.status === 401) {
          sessionStorage.removeItem('jwt_token');
          window.location.href = `/${lang}/login`;
          return;
        }

        if (!res.ok) throw new Error('Analysis failed');

        const data = await res.json();
        document.getElementById('progress').classList.add('hidden');
        displayResults(data);
      } catch (err) {
        document.getElementById('progress').classList.add('hidden');
        analyzeBtn.disabled = false;
        alert('Error: ' + err.message);
      }
    });

    function displayResults(data) {
      const resultsDiv = document.getElementById('results');
      const riskEmoji = { low: '🟢', medium: '🟡', high: '🔴', critical: '🔴🔴' }[data.sensitivity_level] || '🟡';
      const riskLabel = i18n.risk[data.sensitivity_level] || data.sensitivity_level;

      let sensitiveDataHtml = '';
      if (data.sensitive_data) {
        const categories = [
          { key: 'personal', label: i18n.analyze.personal_data, icon: '👤' },
          { key: 'financial', label: i18n.analyze.financial_data, icon: '💰' },
          { key: 'strategic', label: i18n.analyze.strategic_data, icon: '🔒' },
          { key: 'credentials', label: i18n.analyze.credentials, icon: '🔑' },
          { key: 'health', label: i18n.analyze.health_data, icon: '⚕️' },
        ];

        sensitiveDataHtml = categories.map(cat => {
          const items = data.sensitive_data[cat.key];
          if (!items || items.length === 0) return '';
          return `<div class="bg-white rounded-xl border border-slate-200 p-4 mb-3">
            <p class="font-medium text-slate-800 mb-2">${cat.icon} ${cat.label}</p>
            <div class="flex flex-wrap gap-2">
              ${items.map(item => `<span class="px-3 py-1 bg-red-50 text-red-700 rounded-lg text-sm">${item}</span>`).join('')}
            </div>
          </div>`;
        }).join('') || `<p class="text-green-600">✅ ${i18n.analyze.none_found}</p>`;
      }

      resultsDiv.innerHTML = `
        <div class="bg-white rounded-2xl border border-slate-200 p-6 mb-6">
          <h2 class="text-xl font-bold text-slate-900 mb-4">${i18n.analyze.result_title}</h2>
          <div class="mb-4">
            <p class="text-sm text-slate-500">${i18n.analyze.doc_type}</p>
            <p class="text-lg font-medium text-slate-800">${data.document_type || '—'}</p>
          </div>
          <div class="mb-4">
            <p class="text-sm text-slate-500">${i18n.result.sensitivity_level}</p>
            <div class="mt-1"><span class="text-lg">${riskEmoji}</span> <span class="font-medium text-slate-800">${riskLabel}</span></div>
          </div>
        </div>

        <div class="mb-6">
          <h3 class="font-bold text-slate-800 mb-3">${i18n.analyze.sensitive_data}</h3>
          ${sensitiveDataHtml}
        </div>

        <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-6 text-center">
          <p class="text-green-800 font-medium">${i18n.analyze.file_deleted}</p>
          <p class="text-green-600 text-sm">${i18n.analyze.deleted_at}: ${data.deleted_at || '—'}</p>
        </div>

        <div class="text-center">
          <button onclick="window.location.reload()" class="px-6 py-3 bg-slate-100 text-slate-700 font-medium rounded-xl hover:bg-slate-200 transition-colors">
            ${i18n.analyze.analyze_another}
          </button>
        </div>
      `;
      resultsDiv.classList.remove('hidden');
    }
  </script>
</Layout>