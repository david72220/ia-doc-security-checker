---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, tObj } from '../../i18n/index';

export function getStaticPaths() {
  return [{ params: { lang: 'fr' } }, { params: { lang: 'en' } }];
}

const lang = getLangFromUrl(Astro.url);
const i18n = tObj(lang);

const businessTypes = [
  {
    id: 'autoentrepreneur',
    label: i18n.home.autoentrepreneur,
    desc: i18n.home.autoentrepreneur_desc,
    icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
    color: 'blue',
  },
  {
    id: 'tpe',
    label: i18n.home.tpe,
    desc: i18n.home.tpe_desc,
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3-1.5L12 21l3-1.5L19 21z',
    color: 'green',
  },
  {
    id: 'pme',
    label: i18n.home.pme,
    desc: i18n.home.pme_desc,
    icon: 'M3 21h18M3 10h18M5 6l7-3 7 3M4 10v11M20 10v11M8 14v3M12 14v3M16 14v3',
    color: 'purple',
  },
];

const steps = [
  { num: 1, title: i18n.home.step1, desc: i18n.home.step1_desc },
  { num: 2, title: i18n.home.step2, desc: i18n.home.step2_desc },
  { num: 3, title: i18n.home.step3, desc: i18n.home.step3_desc },
];

const colorMap: Record<string, string> = {
  blue: 'bg-blue-50 border-blue-200 hover:border-blue-400 hover:bg-blue-100 text-blue-900',
  green: 'bg-green-50 border-green-200 hover:border-green-400 hover:bg-green-100 text-green-900',
  purple: 'bg-purple-50 border-purple-200 hover:border-purple-400 hover:bg-purple-100 text-purple-900',
};
---

<Layout>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-slate-50 to-white py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 mb-4">
        {i18n.home.title}
      </h1>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        {i18n.home.subtitle}
      </p>
    </div>
  </section>

  <!-- Business type selection -->
  <section class="py-12 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-slate-800 text-center mb-8">
        {i18n.home.select_business_type}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {businessTypes.map((bt) => (
          <a
            href={`/${lang}/tableau?type=${bt.id}`}
            class={`block p-6 rounded-2xl border-2 transition-all ${colorMap[bt.color]}`}
          >
            <div class="flex flex-col items-center text-center">
              <svg class="w-12 h-12 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={bt.icon} />
              </svg>
              <h3 class="text-xl font-bold mb-2">{bt.label}</h3>
              <p class="text-sm opacity-80">{bt.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-white py-12 px-4 border-t border-slate-100">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-slate-800 text-center mb-10">
        {i18n.home.how_it_works}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
        {steps.map((step) => (
          <div class="flex flex-col items-center text-center">
            <div class="w-10 h-10 rounded-full bg-blue-600 text-white font-bold flex items-center justify-center mb-4">
              {step.num}
            </div>
            <h3 class="font-semibold text-slate-800 mb-1">{step.title}</h3>
            <p class="text-sm text-slate-500">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Login CTA -->
  <section class="py-12 px-4">
    <div class="max-w-3xl mx-auto bg-slate-900 rounded-2xl p-8 text-center">
      <p class="text-slate-300 mb-4">{i18n.home.have_document}</p>
      <a
        href={`/${lang}/login`}
        class="inline-block px-6 py-3 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 transition-colors"
      >
        {i18n.home.login_link}
      </a>
    </div>
  </section>
</Layout>