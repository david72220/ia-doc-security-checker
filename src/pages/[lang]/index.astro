---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, tObj } from '../../i18n/index';

export function getStaticPaths() {
  return [{ params: { lang: 'fr' } }, { params: { lang: 'en' } }];
}

const lang = getLangFromUrl(Astro.url);
const i18n = tObj(lang);

const steps = [
  { num: 1, title: i18n.home.step1, desc: i18n.home.step1_desc },
  { num: 2, title: i18n.home.step2, desc: i18n.home.step2_desc },
  { num: 3, title: i18n.home.step3, desc: i18n.home.step3_desc },
];
---

<Layout title={i18n.home.title}>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-slate-50 to-white py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 mb-4">
        {i18n.home.title}
      </h1>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-8">
        {i18n.home.subtitle}
      </p>
      <a
        href={`/${lang}/tableau`}
        class="inline-block px-8 py-4 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 transition-colors text-lg"
      >
        {lang === 'fr' ? 'Vérifier un document' : 'Check a document'}
      </a>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-white py-12 px-4 border-t border-slate-100">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold text-slate-800 text-center mb-10">
        {i18n.home.how_it_works}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
        {steps.map((step) => (
          <div class="flex flex-col items-center text-center">
            <div class="w-10 h-10 rounded-full bg-blue-600 text-white font-bold flex items-center justify-center mb-4">
              {step.num}
            </div>
            <h3 class="font-semibold text-slate-800 mb-1">{step.title}</h3>
            <p class="text-sm text-slate-500">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
