---
import '../styles/global.css';
import { getLangFromUrl, tObj } from '../i18n/index';

const lang = getLangFromUrl(Astro.url);
const i18n = tObj(lang);
const pathname = Astro.url.pathname;

// Normalize pathname for comparison (remove lang prefix)
const normalizedPath = pathname.replace(/^\/(fr|en)/, '') || '/';

const navItems = [
  { href: `/${lang}/tableau`, label: i18n.nav.dashboard, active: normalizedPath === '/tableau' },
  { href: `/${lang}/a-propos`, label: i18n.nav.about, active: normalizedPath === '/a-propos' },
  { href: `/${lang}/login`, label: i18n.nav.login, active: normalizedPath === '/login' },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={i18n.home.subtitle}
    />
    <title>{i18n.home.title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      // Prevent FOUC: set lang before render
      const saved = localStorage.getItem('preferred_lang');
      if (saved && saved !== document.documentElement.lang) {
        const newPath = window.location.pathname.replace(/^\/(fr|en)?/, '/' + saved);
        if (newPath !== window.location.pathname) {
          window.location.pathname = newPath;
        }
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href={`/${lang}`} class="flex items-center gap-2">
            <svg class="w-8 h-8 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            <span class="font-bold text-lg text-slate-900 hidden sm:block">
              {i18n.home.title}
            </span>
          </a>

          <!-- Nav -->
          <nav class="flex items-center gap-1">
            {navItems.map((item) => (
              <a
                href={item.href}
                class={`px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
                  item.active
                    ? 'bg-blue-50 text-blue-700'
                    : 'text-slate-600 hover:text-slate-900 hover:bg-slate-100'
                }`}
              >
                {item.label}
              </a>
            ))}

            <!-- Language toggle -->
            <div class="ml-2 flex items-center rounded-lg border border-slate-200 overflow-hidden lang-toggle">
              <button
                id="lang-fr"
                class={`px-3 py-1.5 text-sm font-medium lang-toggle ${
                  lang === 'fr' ? 'bg-blue-600 text-white' : 'text-slate-600 hover:bg-slate-100'
                }`}
              >
                FR
              </button>
              <button
                id="lang-en"
                class={`px-3 py-1.5 text-sm font-medium lang-toggle ${
                  lang === 'en' ? 'bg-blue-600 text-white' : 'text-slate-600 hover:bg-slate-100'
                }`}
              >
                EN
              </button>
            </div>
          </nav>
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 text-slate-300 py-8 mt-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-sm text-slate-400 mb-2">{i18n.footer.disclaimer}</p>
        <p class="text-xs text-slate-500">{i18n.footer.made_by}</p>
      </div>
    </footer>

    <!-- Lang toggle script -->
    <script is:inline>
      document.getElementById('lang-fr')?.addEventListener('click', () => {
        localStorage.setItem('preferred_lang', 'fr');
        const path = window.location.pathname.replace(/^\/(fr|en)?/, '/fr');
        window.location.pathname = path;
      });
      document.getElementById('lang-en')?.addEventListener('click', () => {
        localStorage.setItem('preferred_lang', 'en');
        const path = window.location.pathname.replace(/^\/(fr|en)?/, '/en');
        window.location.pathname = path;
      });
    </script>
  </body>
</html>